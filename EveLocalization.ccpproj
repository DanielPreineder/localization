ProjectGuid: C74BAD74-2B1A-437C-BB05-BFB611FFE669

Imports:
- ../../../../../../sdk/telemetry/2.0g/telemetry_2.0g.yaml
- ../../../../../../sdk/boost/1_45_0/boost_1_45_0.yaml
- ../../../carbon/src/core_project.yaml
- ../../../carbon/src/manifests/manifests.props

# Settings from the General section, for all configurations
General:
  ConfigurationType: DynamicLibrary
  UseOfMfc: false

# Compiler settings for all configurations
ClCompile:
  EnableEnhancedInstructionSet: StreamingSIMDExtensions2
  WarningLevel: Level3
  TreatWarningAsError: true
  BufferSecurityCheck: false
  PrecompiledHeader: Use
  PrecompiledHeaderFile: stdafx.h
  PrecompiledHeaderOutputFile: $(IntDir)trinity.pch
  PreprocessorDefinitions:
  - UNICODE
  - _UNICODE
  - BLUE_DLL_NAME=EveLocalization

# Linker settings for all configurations
Link:
  GenerateDebugInformation: true
  ProgramDatabaseFile: $(TargetDir)$(TargetName).pdb
  AdditionalDependencies:
  - usp10.lib

Configurations:
  Debug|Win32,x64:
    Imports:
    - ../../../carbon/src/blue/uses_blue.yaml
    General: 
      TargetName: $(ProjectName)_d
      TargetExt: .dll
      LinkIncremental: true
      # The config type is used for selecting the manifest file - usually the same as the configuration
      CcpConfigType: Debug
    ClCompile:
      PreprocessorDefinitions:
      - _DEBUG
      Optimization: Disabled
      RuntimeLibrary: MultiThreadedDebugDLL
      DebugInformationFormat: EditAndContinue

  Release|Win32,x64:
    Imports:
    - ../../../carbon/src/blue/uses_blue.yaml
    - EveLocalization_release.yaml
    General:
      TargetName: $(ProjectName)
      TargetExt: .dll

  Release_26|Win32,x64:
    Imports:
    - ../../../carbon/src/blue/uses_blue_26.yaml
    - EveLocalization_release.yaml
    General:
      TargetName: $(ProjectName)
      TargetExt: .pyd

  Release_27|Win32,x64:
    Imports:
    - ../../../carbon/src/blue/uses_blue_27.yaml
    - EveLocalization_release.yaml
    General:
      TargetName: $(ProjectName)
      TargetExt: .pyd
